# Discord personal user token (for local testing only)
DISCORD_USER_TOKEN=replace_with_discord_user_token

# Gateway proxy: leave empty to use system proxy, set to "none" for direct connect,
# or set an explicit proxy such as socks5://127.0.0.1:7890
# DISCORD_GATEWAY_PROXY=none

# You can paste Discord channel URLs directly. Multiple values can be comma-separated.
DISCORD_CHANNEL_URLS=https://discord.com/channels/YOUR_GUILD_ID/YOUR_CHANNEL_ID

# Optional explicit filters. The URL above already contains these IDs.
# DISCORD_CHANNEL_IDS=YOUR_CHANNEL_ID
# DISCORD_ALLOWED_GUILD_IDS=YOUR_GUILD_ID

ALERT_PREFIX=[Discord]
LOG_LEVEL=INFO

# Gmail SMTP. Gmail usually requires an App Password, not your normal account password.
GMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=replace_with_gmail_app_password
SMTP_FROM=your_email@gmail.com
SMTP_TO=receiver@example.com

# Lark / Feishu custom bot webhook
LARK_ENABLED=false
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/replace_me
LARK_SECRET=

# DingTalk custom robot webhook
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=replace_me
DINGTALK_SECRET=